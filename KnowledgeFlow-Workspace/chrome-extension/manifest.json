{
  "manifest_version": 3,
  "name": "KnowledgeFlow",
  "version": "0.1.0",
  "description": "Local-first web clipper that routes semantic text snippets into your Obsidian vault.",
  "permissions": [],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"]
    }
  ],
  "commands": {
    "trigger-clip": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Clip selected text to Obsidian"
    }
  }
}
